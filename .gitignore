```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Virtual environments
venv/
.venv/
env/

# Logs
*.log

# Temporary files
*.tmp
*.swp
*.swo

# Coverage reports
coverage/
htmlcov/
.coverage

# Pytest cache
.pytest_cache/

# MyPy cache
.mypy_cache/

# Distribution and build artifacts
dist/
build/
*.egg-info/

# Environment files
.env
.env.local
*.env.*

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo

# System files
.DS_Store
Thumbs.db
```
```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Logs and temp files
*.log
*.tmp

# Environment files
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Dependencies
.venv/
venv/
node_modules/

# Build artifacts
dist/
build/
target/

# Coverage reports
coverage/
htmlcov/
.coverage

# OS specific
.DS_Store
Thumbs.db
```